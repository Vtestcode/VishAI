# Required
OPENAI_API_KEY=sk-your-openai-api-key-here
# CONTACT_EMAIL=you@example.com

# Model
# MODEL_NAME=gpt-4o-mini
# REASONING_MODEL_NAME=gpt-4.1-mini

# Remote MCP
# ENABLE_MCP=true
# MCP_SERVER_URL=<Add MCP URL>/sse
# MCP_SERVER_LABEL=rag_tools
# MCP_SERVER_DESCRIPTION=Remote tools exposed by the portfolio MCP server
# MCP_REQUIRE_APPROVAL=never
# MCP_ALLOWED_TOOLS=search_docs,lookup_project

# Redis cache
# REDISCLOUD_URL=redis://default:password@host:port
# REDIS_CACHE_TTL_SECONDS=300
# TOOL_ANSWER_CACHE_TTL_SECONDS=180

# Retrieval
# TOP_K=5
# RETRIEVAL_CANDIDATE_K=15
# QUERY_REWRITE_COUNT=3
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200
# ENABLE_RERANKING=true
# ENABLE_ANSWER_VALIDATION=true
# ENABLE_RAPTOR=true
# RAPTOR_GROUP_SIZE=6

# S3 document storage
AWS_REGION=us-east-1
S3_BUCKET=your-rag-docs-bucket
S3_PREFIX=knowledge-base/
RAG_MANIFEST_KEY=knowledge-base/.rag-index-manifest.json
CHAT_LOG_BUCKET=your-rag-docs-bucket
CHAT_LOG_PREFIX=chat-logs/

# Pinecone
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=rag-chatbot
PINECONE_NAMESPACE=rag-docs
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

CHAT_LOG_BUCKET=
CHAT_LOG_PREFIX=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
